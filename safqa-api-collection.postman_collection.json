{
  "info": {
    "name": "Safqa API Collection",
    "_postman_id": "safqa-api-v1",
    "description": "Complete API collection for Safqa (صفقة) multi-vendor e-commerce platform.\n\nSetup:\n1. Set `base_url` variable to `http://127.0.0.1:8000/api`\n2. Login as Admin/Seller/Customer → copy token → set `admin_token`, `seller_token`, `customer_token`\n3. Set `Accept-Language: ar` or `en` in headers for language switching",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://127.0.0.1:8000/api" },
    { "key": "admin_token",    "value": "" },
    { "key": "seller_token",   "value": "" },
    { "key": "customer_token", "value": "" },
    { "key": "lang",           "value": "en" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register — Customer",
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/register",
            "header": [{"key":"Accept-Language","value":"{{lang}}"},{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ahmed Customer\",\n  \"email\": \"customer@safqa.com\",\n  \"phone\": \"0512345678\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"role\": \"customer\"\n}" }
          }
        },
        {
          "name": "Register — Seller",
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/register",
            "header": [{"key":"Accept-Language","value":"{{lang}}"},{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mohamed Seller\",\n  \"email\": \"seller@safqa.com\",\n  \"phone\": \"0598765432\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"role\": \"seller\",\n  \"store_name\": \"Mohamed Store\"\n}" }
          }
        },
        {
          "name": "Login — Admin",
          "event": [{"listen":"test","script":{"exec":["var json = pm.response.json();","if(json.data && json.data.token) pm.collectionVariables.set('admin_token', json.data.token);"]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/login",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@safqa.com\",\n  \"password\": \"Admin@12345\"\n}" }
          }
        },
        {
          "name": "Login — Seller",
          "event": [{"listen":"test","script":{"exec":["var json = pm.response.json();","if(json.data && json.data.token) pm.collectionVariables.set('seller_token', json.data.token);"]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/login",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"seller@safqa.com\",\n  \"password\": \"Password@123\"\n}" }
          }
        },
        {
          "name": "Login — Customer",
          "event": [{"listen":"test","script":{"exec":["var json = pm.response.json();","if(json.data && json.data.token) pm.collectionVariables.set('customer_token', json.data.token);"]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/login",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"customer@safqa.com\",\n  \"password\": \"Password@123\"\n}" }
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET", "url": "{{base_url}}/auth/me",
            "header": [{"key":"Authorization","value":"Bearer {{admin_token}}"},{"key":"Accept-Language","value":"{{lang}}"}]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/refresh",
            "header": [{"key":"Authorization","value":"Bearer {{admin_token}}"}]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/logout",
            "header": [{"key":"Authorization","value":"Bearer {{admin_token}}"}]
          }
        }
      ]
    },

